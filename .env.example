# ============================================
# KuliahOnlineIT - Environment Variables Example
# ============================================
# Copy file ini ke .env dan sesuaikan nilainya
#
#   cp .env.example .env
#
# ============================================

# --- PocketBase ---
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=your-admin-password

# --- OAuth Providers (PocketBase Admin UI) ---
# Set OAuth2 credentials via PocketBase admin panel at http://localhost:8090/_/
# Variabel di bawah ini untuk referensi saja
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Midtrans ---
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# --- Storage ---
# Development: storage bawaan PocketBase
# Production: arahkan ke S3-compatible storage
STORAGE_BUCKET=kuliahonlineit
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- App ---
NEXT_PUBLIC_APP_NAME=KuliahOnlineIT
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090
# Kosongkan untuk menyembunyikan tombol OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GITHUB_CLIENT_ID=
